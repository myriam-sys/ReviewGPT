# ══════════════════════════════════════════════════════════════════════════════
# ReviewGPT — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API

# Your project's REST API base URL
SUPABASE_URL=https://your-project-id.supabase.co

# Key used by the Supabase Python SDK (supabase.create_client) for server-side
# DB writes.  Set this to your service_role key so inserts bypass Row-Level Security.
# Found in: Supabase dashboard → Project Settings → API → service_role (secret)
SUPABASE_KEY=your-supabase-service-role-key

# The anon/public key (safe for server-side use; do not use the service_role key in client code)
SUPABASE_ANON_KEY=your-supabase-anon-key

# The service_role key — grants full DB access, use only in trusted server-side code
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Direct PostgreSQL connection string for pgvector operations via vecs
# Found in: Supabase dashboard → Project Settings → Database → Connection string (URI)
SUPABASE_DB_URL=postgresql://postgres:your-db-password@db.your-project-id.supabase.co:5432/postgres

# ── Groq ──────────────────────────────────────────────────────────────────────
# Found in: https://console.groq.com/keys

GROQ_API_KEY=gsk_your-groq-api-key

# The Groq model to use for chat completions
# llama-3.1-8b-instant is fast and accurate; mixtral-8x7b-32768 supports longer context
GROQ_MODEL=llama-3.1-8b-instant

# ── Embeddings ────────────────────────────────────────────────────────────────
# HuggingFace model ID for generating multilingual embeddings
# Model will be downloaded automatically on first run via sentence-transformers
EMBEDDING_MODEL=intfloat/multilingual-e5-large

# Dimension of the embedding vectors produced by the model above (1024 for multilingual-e5-large)
EMBEDDING_DIMENSION=1024

# ── App ───────────────────────────────────────────────────────────────────────
# Environment label: development | staging | production
APP_ENV=development

# Number of review chunks to retrieve per RAG query (top-k)
RAG_TOP_K=5

# Maximum number of tokens for the LLM response
LLM_MAX_TOKENS=1024
